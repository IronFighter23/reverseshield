{
    "name": "reverseshield/laravel",
    "description": "ReverseShield middleware for Laravel — bot & scraper defense. Fail-open by design.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "middleware", "security", "bot-detection", "honeypot"],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "ReverseShield\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ReverseShield\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ReverseShield\\Laravel\\ReverseShieldServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        },
        "audit": {
            "abandoned": "ignore",
            "ignore": [
                "PKSA-3r5d-mb8f-1qw9",
                "PKSA-m5cs-t1y6-qpcs",
                "PKSA-mdq4-51ck-6kdq",
                "PKSA-8qx3-n5y5-vvnd",
                "PKSA-w7xr-vk7n-rstm",
                "PKSA-q46n-4fdk-zjr4",
                "PKSA-qzrn-rnz3-85w1"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}