# Reporting API — environment variables. Copy to .env and edit as needed.
# The API boots cleanly with none of these set; every field has a safe local-dev default.

# Port for the HTTP listener. Default: 3001
# RS_PORT=3001

# SQLite database file location. Default: services/reporting/api/data/reporting.sqlite
# RS_DATABASE_PATH=/var/lib/reverseshield/reporting.sqlite

# Origin allowed to read (dashboard). The events ingestion endpoint always accepts
# Origin: * regardless of this value — browser agents install on arbitrary sites.
# RS_CORS_DASHBOARD_ORIGIN=http://localhost:5173

# Public URL of this API. Used to build the install snippet returned by POST /sites.
# RS_PUBLIC_URL=http://localhost:3001

# Pepper mixed into ip_hash. Set to a random string in production to prevent cross-install
# correlation of the same IP. Leave empty for local dev.
# RS_IP_HASH_PEPPER=

# Path to the built agent-js bundle for the /agent.js endpoint. Default resolves via the
# monorepo layout; override if you're running the API standalone from packages/agent-js.
# RS_AGENT_BUNDLE_PATH=/opt/reverseshield/agent.js
